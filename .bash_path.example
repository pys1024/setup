# Example format for machine-specific environment and PATH settings.

export JAVA_HOME="$HOME/java/jdk1.8.0_191"
export JRE_HOME="$JAVA_HOME/jre"
export CLASSPATH=".:$JAVA_HOME/lib:$JRE_HOME/lib${CLASSPATH:+:$CLASSPATH}"

PATH_PREPEND_DIRS=(
    "$HOME/.local/bin"
    "$JAVA_HOME/bin"
    "$JRE_HOME/bin"
)

PATH_APPEND_DIRS=(
    "$HOME/.platformio/penv/bin"
)
