[alias]
    lgg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %Cgreen(%cr) %C(bold blue)<%an>%Creset %n%f%n' --abbrev-commit -5
    lgga = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %Cgreen(%cr) %C(bold blue)<%an>%Creset %n%f%n' --abbrev-commit -5 --all
    lg = log --graph --decorate --color -5
    st = status
    a = add
    b = branch
    c = commit
    cp = cherry-pick
    cpa = cherry-pick --abort
    cpc = cherry-pick --continue
    ca = commit --amend
    can = commit --amend --no-edit
    d = diff
    f = fetch
    i = init
    l = lgg
    p = pull
    # pu = push -u origin main
    pu = "!f(){ u=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null); if [ -n \"$u\" ]; then r=${u%%/*}; b=${u#*/}; else r=origin; b=$(git symbolic-ref --short -q HEAD) || { echo 'detached HEAD' >&2; exit 1; }; fi; git push -u \"$r\" \"$b\"; }; f"
    # pu = push origin HEAD:refs/for/master
    # pu = "!f(){ u=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null); if [ -n \"$u\" ]; then r=${u%%/*}; b=${u#*/}; else r=origin; b=$(git symbolic-ref --short -q HEAD) || { echo 'detached HEAD' >&2; exit 1; }; fi; git push \"$r\" HEAD:refs/for/\"$b\"; }; f"
    r = rebase
    ra = rebase --abort
    rc = rebase --continue
    ri = rebase -i
    rs = restore
    s = status
    t = tag
    chk = checkout
    wt = worktree
[color]
    status = always
    diff = always
    branch = always
    interactive = always
[core]
    autocrlf = input
    editor = vim
    pager = delta
[user]
    name = pengyongsheng
    email = pengyongsheng@goodix.com
[pull]
    rebase = true
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection
    line-number = true
    side-by-side = true
    syntax-theme = ansi
[advice]
    skippedCherryPicks = false
[merge]
    conflictStyle = zdiff3
[http]
    proxy = 127.0.0.1:8118
[https]
    proxy = 127.0.0.1:8118
